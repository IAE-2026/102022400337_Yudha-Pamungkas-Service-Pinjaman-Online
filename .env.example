APP_NAME="Loan Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001
APP_PORT=8001

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=loan-db
DB_PORT=3306
DB_DATABASE=loans_db
DB_USERNAME=loan_user
DB_PASSWORD=your_secure_password_here
DB_ROOT_PASSWORD=root_secure_password_here

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file

# ─── IAE API Key ────────────────────────────────────────────────────────────
# Must match your NIM. All incoming requests must send:  X-IAE-KEY: 102022400337
IAE_KEY=102022400337

# ─── Inter-Service URLs ─────────────────────────────────────────────────────
# Set to the actual IP/hostname of each teammate's laptop when running on different machines.
# Example: http://192.168.1.42:8002
USER_AUTH_SERVICE_URL=http://localhost:8002
PAYMENT_SERVICE_URL=http://localhost:8003

# ─── Swagger ────────────────────────────────────────────────────────────────
L5_SWAGGER_GENERATE_ALWAYS=true
L5_SWAGGER_CONST_HOST=http://localhost:8001
L5_SWAGGER_UI_DOC_EXPANSION=list

# ─── GraphQL ────────────────────────────────────────────────────────────────
GRAPHIQL_ENABLED=true
