<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true">
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV"              value="testing"/>
        <env name="APP_KEY"              value="base64:dGVzdGtleTEyMzQ1Njc4OTAxMjM0NTY3ODkwMTI="/>
        <env name="APP_DEBUG"            value="true"/>
        <env name="DB_CONNECTION"        value="sqlite"/>
        <env name="DB_DATABASE"          value=":memory:"/>
        <env name="IAE_KEY"              value="102022400337"/>
        <env name="CACHE_DRIVER"         value="array"/>
        <env name="SESSION_DRIVER"       value="array"/>
        <env name="QUEUE_CONNECTION"     value="sync"/>
        <!-- Leave blank so HTTP calls to other services are skipped in tests -->
        <env name="USER_AUTH_SERVICE_URL" value=""/>
        <env name="PAYMENT_SERVICE_URL"   value=""/>
        <!-- Disable Swagger auto-generation during tests -->
        <env name="L5_SWAGGER_GENERATE_ALWAYS" value="false"/>
    </php>
</phpunit>
